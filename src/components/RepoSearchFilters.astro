---
interface Props {
  categories: string[];
  tags: string[];
}

const { categories, tags } = Astro.props;
---

<section class="toolbar" aria-label="Search and filter repositories">
  <h2 class="toolbar__title">Find Your Next AI Build Block</h2>

  <form id="repo-filters" class="toolbar__grid">
    <label class="toolbar__field" for="search-input">
      <span>Search</span>
      <input id="search-input" name="search" type="search" placeholder="Search by name, description, tag..." />
    </label>

    <label class="toolbar__field" for="category-select">
      <span>Category</span>
      <select id="category-select" name="category">
        <option value="all">All categories</option>
        {categories.map((category) => <option value={category}>{category}</option>)}
      </select>
    </label>

    <label class="toolbar__field" for="tag-select">
      <span>Tag</span>
      <select id="tag-select" name="tag">
        <option value="all">All tags</option>
        {tags.map((tag) => <option value={tag}>{tag}</option>)}
      </select>
    </label>

    <label class="toolbar__check" for="featured-only">
      <input id="featured-only" name="featured" type="checkbox" />
      <span>Featured only</span>
    </label>
  </form>
</section>
