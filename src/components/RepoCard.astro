---
interface RepoViewModel {
  id: string;
  fullName: string;
  url: string;
  description: string;
  category: string;
  tags: string[];
  featured: boolean;
}

interface Props {
  repo: RepoViewModel;
}

const { repo } = Astro.props;
---

<article
  class="repo-card"
  data-repo-id={repo.id}
  data-category={repo.category}
  data-tags={repo.tags.join("|")}
  data-featured={repo.featured ? "1" : "0"}
  data-query={`${repo.fullName} ${repo.description} ${repo.tags.join(" ")}`.toLowerCase()}
>
  <header class="repo-card__head">
    <a class="repo-card__title" href={repo.url} target="_blank" rel="noreferrer noopener">
      {repo.fullName}
    </a>
    {repo.featured ? <span class="repo-badge">featured</span> : null}
  </header>

  <p class="repo-card__description">{repo.description}</p>

  <ul class="repo-card__meta" aria-label={`Repository metadata for ${repo.fullName}`}>
    <li>{repo.category}</li>
    <li>GitHub resource</li>
  </ul>

  <div class="repo-card__tags" aria-label="Tags">
    {repo.tags.length
      ? repo.tags.map((tag) => <span class="repo-tag">#{tag}</span>)
      : <span class="repo-tag repo-tag--muted">#untagged</span>}
  </div>
</article>
