---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AI Resource Atlas",
  description = "A curated, scrollable overview of high-impact AI GitHub repositories.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#102a43" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to resource list</a>
    <div class="bg-layer" aria-hidden="true"></div>
    <main id="content" class="app-shell">
      <slot />
    </main>
  </body>
</html>
